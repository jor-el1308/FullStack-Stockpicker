# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=stockpicker
DB_PASSWORD=changeme
DB_NAME=stockpicker
# Shared team database (optional) - point DB_HOST/DB_USER/DB_PASSWORD above
# at an external MySQL instead of a local install, e.g. Aiven's always-free
# tier (https://aiven.io/free-mysql-database). Most external hosts require
# TLS - set DB_SSL=true, and optionally DB_SSL_CA to a downloaded CA cert
# path for proper verification (without it, DB_SSL=true still encrypts the
# connection but doesn't verify the server certificate). See README's
# "Shared team database" section.
DB_SSL=false
DB_SSL_CA=

# Auth (Person 1)
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

# Subscription/Paywall (Person 2) - Stripe TEST MODE checkout.
# 1. Sign up free at https://dashboard.stripe.com/register (no business
#    verification needed to use test mode).
# 2. Make sure the "Test mode" toggle in the dashboard is ON.
# 3. Go to Developers -> API keys and copy the "Secret key" (starts sk_test_).
# 4. Paste it below. Never commit a real (sk_live_) key - test keys only
#    move fake money, live keys move real money.
STRIPE_SECRET_KEY=

# Stripe webhook (reliable activation path - see subscription.service.js's
# handleCheckoutSessionCompleted()). Without this, activation only happens
# if the user's browser makes it back to /activate after paying; the
# webhook activates the account directly from Stripe's servers even if the
# user closes the tab first.
# 1. Local dev: install the Stripe CLI (https://stripe.com/docs/stripe-cli),
#    run `stripe listen --forward-to localhost:4000/api/subscription/webhook`,
#    and paste the "whsec_..." it prints below.
# 2. Deployed: Dashboard -> Developers -> Webhooks -> Add endpoint, pointing
#    at https://<your-domain>/api/subscription/webhook, subscribed to the
#    checkout.session.completed event; copy its signing secret below.
STRIPE_WEBHOOK_SECRET=

# Subscription/Paywall (Person 2) - welcome email sent once activation
# payment succeeds (server/src/utils/mailer.js). Works with any SMTP
# provider. Easiest for local testing: sign up free at
# https://ethereal.email (fake inbox, nothing actually gets delivered,
# just lets you see the rendered email) and paste its generated
# host/user/password below. For a real provider, Gmail needs an "app
# password" (not your normal password) with SMTP_HOST=smtp.gmail.com,
# SMTP_PORT=587. If these are left blank, sending is skipped (logged, not
# an error) so it never blocks the paywall/activation flow.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Stock Screener <no-reply@example.com>"

# Notifications (Person 5)
TELEGRAM_BOT_TOKEN=
WHATSAPP_API_TOKEN=

# AI recommendation step (Person 1, section 6 of requirement doc) - sends
# shortlisted stocks to Gemini for qualitative analysis after a screen runs
# (server/src/services/ai.service.js). Get a free key (no credit card) at
# https://aistudio.google.com/app/apikey - click "Create API key". Free tier
# is rate-limited (fine for dev/demo) - see server/src/services/ai.service.js
# for the model used (gemini-2.5-flash).
AI_RECOMMENDATION_API_KEY=
