# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=stockpicker
DB_PASSWORD=changeme
DB_NAME=stockpicker

# Auth (Person 1)
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

# Data pipeline (Person 2) - pick one provider and fill in the key
STOCK_DATA_PROVIDER=alpha_vantage
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=
YAHOO_FINANCE_API_KEY=

# Subscription/Paywall (Person 2) - Stripe TEST MODE checkout.
# 1. Sign up free at https://dashboard.stripe.com/register (no business
#    verification needed to use test mode).
# 2. Make sure the "Test mode" toggle in the dashboard is ON.
# 3. Go to Developers -> API keys and copy the "Secret key" (starts sk_test_).
# 4. Paste it below. Never commit a real (sk_live_) key - test keys only
#    move fake money, live keys move real money.
STRIPE_SECRET_KEY=

# Notifications (Person 5)
TELEGRAM_BOT_TOKEN=
WHATSAPP_API_TOKEN=

# Optional AI recommendation step (Person 5, section 6 of requirement doc)
AI_RECOMMENDATION_API_KEY=
