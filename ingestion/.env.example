# Same MySQL instance/credentials as server/.env - keep these in sync.
DB_USER=db
DB_PASSWORD=example
DB_NAME=defaultdb
DB_HOST=db
DB_PORT=3306
DB_SSL=true
DB_SSL_CA=../server/aiven-ca.pem
JWT_SECRET=change-this-in-production

# How much daily price history to pull per ticker (yfinance period string:
# "1y", "2y", "5y", "max", etc.)
PRICE_HISTORY_PERIOD=2y

# --- Dynamic universe discovery (universe.py) ---
# Set to true to discover the stock list via yfinance EquityQuery/screen()
# instead of the fixed 15-stock list in tickers.py.
USE_DYNAMIC_UNIVERSE=false

# Market cap floors (raw units, e.g. 10000000000 = $10B) used to filter
# the discovered universe.
US_MARKET_CAP_FLOOR=10000000000
SGX_MARKET_CAP_FLOOR=500000000

# Max stocks to pull per exchange group (US, SGX) when using the dynamic
# universe - keep modest for a prototype to limit runtime/rate-limit risk.
MAX_STOCKS_PER_EXCHANGE=50
