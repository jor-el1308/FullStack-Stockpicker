# Config for `docker-compose up` (root-level, separate from server/.env
# which is only used when running the app without Docker).
#
# Copy this to a root .env if you want to override any default:
#   cp .env.example .env
# All of these already have sane defaults baked into docker-compose.yml, so
# this file is optional - the only reason to create it is to set a real
# Stripe test key so the paywall/checkout flow works.

# MySQL root password (used internally by the mysql container, not by the app)
MYSQL_ROOT_PASSWORD=rootpass

# App database user/name - must match on both the mysql and server services,
# which docker-compose.yml already takes care of.
DB_USER=stockpicker
DB_PASSWORD=changeme
DB_NAME=stockpicker

# Shared team database (optional) - point the app at an external MySQL
# instead of the local `mysql` container, e.g. Aiven's always-free tier
# (https://aiven.io/free-mysql-database, no credit card needed). Leave
# DB_HOST unset to keep using the local container. See README's "Shared
# team database" section for the full walkthrough.
DB_HOST=
DB_PORT=3306
# Most external hosts require TLS.
DB_SSL=false
# Optional: path to a downloaded CA cert (readable inside the server
# container, e.g. server/aiven-ca.pem). Without it, DB_SSL=true still
# encrypts the connection but doesn't verify the server certificate.
DB_SSL_CA=

JWT_SECRET=change-this-in-production

# Stripe TEST MODE secret key (starts sk_test_) - get one free at
# https://dashboard.stripe.com/register, Developers -> API keys.
# Leave blank and the app still runs, but the paywall/checkout page won't
# work until this is set.
STRIPE_SECRET_KEY=

# Welcome email + login 2FA codes (server/src/utils/mailer.js). Leave blank
# and the app still runs - login codes get printed to `docker-compose logs
# server` instead of emailed. Easiest for testing: sign up free at
# https://ethereal.email and paste its generated host/user/password below.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Stock Screener <no-reply@example.com>"

STOCK_DATA_PROVIDER=alpha_vantage
ALPHA_VANTAGE_API_KEY=

# Set to false to stop the server container re-seeding sample data on every
# `docker-compose up` (e.g. once you've loaded real data via ingestion/).
AUTO_SEED=true
